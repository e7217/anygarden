# Anygarden cluster — environment variables
#
# Copy this file to `.env` (same directory as the cluster is launched
# from) and override values as needed. Every variable is optional; the
# cluster provides sensible defaults or auto-persists a value in
# ~/.anygarden/ when the variable is unset.

# ── Core server ──────────────────────────────────────────────────
# ANYGARDEN_HOST=127.0.0.1
# ANYGARDEN_PORT=8000
# ANYGARDEN_LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────
# Default: SQLite at ~/.anygarden/anygarden.db. Point at Postgres in prod:
#   ANYGARDEN_DB_URL=postgresql+asyncpg://user:pass@host/db
# ANYGARDEN_DB_URL=sqlite+aiosqlite:////absolute/path/to/anygarden.db

# ── Secrets ──────────────────────────────────────────────────────
# JWT signing secret for session tokens. When unset, the cluster
# auto-creates ~/.anygarden/jwt_secret on first boot and reuses it on
# every subsequent restart. Provide your own value here (e.g. K8s
# secret) to take control of the lifecycle.
# ANYGARDEN_JWT_SECRET=

# Fernet key for encrypting MCP credentials at rest (GitHub PATs,
# Linear API keys, etc.). Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# When unset, the cluster auto-creates ~/.anygarden/mcp_secrets_key on
# first boot (same pattern as ANYGARDEN_JWT_SECRET) so existing MCP
# instances survive restarts. In production, prefer setting this
# explicitly so the key lifecycle is visible.
#
# IMPORTANT: If this key is lost or changes, previously-attached MCP
# credentials become unreadable and must be re-entered via the admin
# UI.
# ANYGARDEN_MCP_SECRETS_KEY=

# ── Runtime mode ─────────────────────────────────────────────────
# ANYGARDEN_DEV=1 enables dev-mode conveniences (e.g. the MCP secrets
# layer accepts an ephemeral fallback key when neither the env var
# nor the persistence file are usable). Production deploys MUST
# leave this unset (or =0) so missing-secret misconfigurations fail
# loudly at boot instead of silently regenerating a throwaway key.
# ANYGARDEN_DEV=0

# ── OpenTelemetry tracing (#420) ─────────────────────────────────
# Off by default — a no-op until enabled AND an endpoint is set.
# ANYGARDEN_OTEL_ENABLED=1
# OTLP/HTTP traces endpoint. A base URL is fine — ``/v1/traces`` is
# appended automatically. For Langfuse use ``<host>/api/public/otel``.
# ANYGARDEN_OTEL_OTLP_ENDPOINT=http://langfuse-host:3000/api/public/otel
# Auth — pick ONE:
#   (a) Langfuse keys (recommended): the Basic header is built for you.
# ANYGARDEN_OTEL_LANGFUSE_PUBLIC_KEY=pk-lf-...
# ANYGARDEN_OTEL_LANGFUSE_SECRET_KEY=sk-lf-...
#   (b) Raw header override (wins over the keys above):
# ANYGARDEN_OTEL_OTLP_HEADERS=Authorization=Basic <base64(public:secret)>
# Optional:
# ANYGARDEN_OTEL_SERVICE_NAME=anygarden-cluster
# ANYGARDEN_OTEL_SAMPLING_RATIO=1.0
# Capture LLM prompt/completion bodies as span attributes (on by default;
# only effective when traffic actually flows through the LLM gateway).
# ANYGARDEN_OTEL_LLM_CAPTURE_CONTENT=1
# ANYGARDEN_OTEL_LLM_CAPTURE_MAX_CHARS=8000
